{
  "name": "full-stack-api",
  "version": "1.0.0",
  "description": "Mandatory Assignment (REST API)",
  "homepage": "https://github.com/reasonsx/rest-api-mandatory-assigment#readme",
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "dist",
      "node_modules",
      "src/**/*.spec.ts"
    ],
    "exec": "npx ts-node ./src/index.ts"
  },
  "bugs": {
    "url": "https://github.com/reasonsx/rest-api-mandatory-assigment/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reasonsx/rest-api-mandatory-assigment.git"
  },
  "license": "ISC",
  "author": "Kamil Kregiel",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start-dev": "nodemon",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.3",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
